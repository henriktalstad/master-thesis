generator client {
  provider     = "prisma-client"
  output       = "../generated/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AppRole {
  ADMIN
  MANAGER
  JANITOR
  TENANT
}

enum InfraspawnAlarmKind {
  ALARM
  FAULT
  OUT_OF_SERVICE
}

enum InfraspawnAlarmSeverity {
  A
  B
  C
  FAULT
}

enum InfraspawnSystemDomain {
  VENTILATION
  HEATING
  SYSTEM
  OTHER
}

enum EnergyPriceSource {
  NORD_POOL
  ENTSOE
}

enum AreaMeasurementBasis {
  BTA // Bruttoareal – standard for næringseiendom
  BRA // Bruksareal – standard for bolig
  NTA // Nettoareal – rom for rom
}

enum IntegrationProvider {
  ELHUB
  CELSIO
  A_VARME
  ENGAGE
  SMARTVATTEN
  STATKRAFT
  FENISTRA
  FAZILE
  ENOCO
  ELVACO_EVO
  INFRASPAWN
  HENTEPLAN
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
  ERROR
  PENDING_SETUP
}

enum IntegrationType {
  ELECTRICITY
  DISTRICT_HEATING
  WASTE
  WATER
  PROPERTY_MANAGEMENT
  METERING_IMPORT
}

enum BackfillState {
  BASELINE
  GAPS
  COMPLETE
}

enum MpcSimulationStatus {
  IDLE
  RUNNING
  COMPLETED
  FAILED
}

enum MpcReplayQuality {
  VALID
  INVALID_FAN
  INSUFFICIENT_DATA
}

enum MpcControlTrack {
  OBSERVED
  EMULATED
  MPC
  DEMAND
}

enum MpcChartSeries {
  COST_TIMELINE
  COMFORT
  LOAD_PROFILE
  EFFECT_SUMMARY
}

enum MpcPriceLoadBand {
  LOW
  MID
  HIGH
  PEAK
}

enum MpcPersistStatus {
  PENDING
  REPLAY_STEPS
  ARTIFACTS
  COMPLETE
  FAILED
}

/// Driftsmodus for MPC — skygge, operatør-godkjenning, eller live BMS.
enum MpcExecutionMode {
  SHADOW
  SUPERVISORY
  LIVE
}

/// Livssyklus for supervisory/writeback-kommandoer mot BMS.
enum MpcSupervisoryStatus {
  predicted
  approved
  queued
  published
  acknowledged
  applied
  rejected
  failed
}

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AllocationTrack {
  CLASSIC
  FENISTRA
  FAZILE
}

enum MeteringPointType {
  ELECTRICITY // Strømforbruk
  HEAT // Fjernvarme / termisk varme (forbruk)
  COOLING // Termisk kjøling, fjernkjøling, chillere (forbruk)
  PRODUCTION // Energiproduksjon: solceller, vindkraft, batterilagring
  WATER // Vannforbruk
}

enum EnergyFlowStage {
  GRID_DELIVERED // AMS / fjernvarme inn over bygningsgrense
  GRID_EXPORTED // Eksport til nett
  CONSUMPTION // El-forbruk på kurs/last (sub-meter eller main)
  PRODUCTION_GROSS // Lokal produksjon ved kilde (PV-inverter, VP-termisk, el-kjel)
  DISTRIBUTION // Termisk energi levert til sone/aggregat (varmemåler ved leveranse)
  CONVERSION_INPUT // El som driver konverteringsenhet (også med i CONSUMPTION-hierarki)
  AMBIENT_SOURCE // Ambient utenfor bygningsgrense (brønnpark, uteluft til VP)
}

enum MeterHierarchyRole {
  TOTAL // Rot som eier summen for sin bærer (Hovedfordeling, AMS-måler)
  BRANCH // Mellomledd
  LEAF // Blad
  STANDALONE // Ikke del av hierarki
}

enum CtPlacement {
  LOAD_BRANCH // CT på kurs — måler last, ser ikke PV
  FEED_MAIN // CT på hovedinnkommer — bi-dir, ser netto grid
  PV_OUTPUT // CT på PV-branch — kun produksjon
  BATTERY // CT på batteri
  THERMAL_PRODUCTION // Varmemåler ved produksjonskilde (varmepumpe, el-kjel)
  THERMAL_DELIVERY // Varmemåler ved leveransepunkt (gulvvarme, ventilasjon)
  AMBIENT // Måler ambient-side (brønnpark før VP)
  UNKNOWN // Ikke avklart — KPI-er må flagges som foreløpige
}

enum BuildingMeteringTopology {
  GRID_AMS_ONLY
  SUB_METER_ONLY
  HYBRID_AMS_PLUS_SUB
  UNKNOWN
}

enum MeterVerificationStatus {
  AUTO
  VERIFIED
  DEFERRED
}

enum SubMeterCategory {
  // --- NS 3031 + ASHRAE energiformål ---
  OPPVARMING // Romoppvarming, radiatorer, gulvvarme, aerotempere
  VENTILASJON // Ventilasjonsaggregat, vifter, batterier
  KJOLING // Komfortkjøling, chillere, DX-anlegg
  BELYSNING // Interiør og eksteriør belysning
  STIKKONTAKT // Plugglaster, kontorutstyr, småapparater
  TAPPEVANN // VVB, varmtvannspumper, forvarming

  // --- Spesialsystemer ---
  HEIS // Heiser, rulletrapper, vertikal transport
  ELBIL_LADING // Elbilladere, hurtigladestasjoner
  IT_DATAROM // Serverrom, UPS, dataromkjøling
  VARMEPUMPE // VP produksjon, kald/varm side, brønnpark
  SOLCELLE // Solcelleanlegg, invertere, batterilagring
  SNOSMELTING // Snøsmelteanlegg, varmekabler ute

  // --- Distribusjon og infrastruktur ---
  FORDELING // Etasje-/romfordeling, underfordeling, hovedtavle
  FELLES // Fellesanlegg i delte bygg
  TEKNISK // Automasjon, styring, tekniske tavler
  PROSESS // Prosesskjøling, laboratorium, verksted, kjøkken

  // --- Annet ---
  ANNET // Egendefinert (bruker spesifiserer i subMeterLabel)
}

enum SubMeterSubCategory {
  // --- OPPVARMING ---
  GULVVARME
  RADIATOR
  KONVEKTOR
  AEROTEMPER
  SNOSMELTING_VARMEKABLER
  VARMEBATTERI

  // --- VENTILASJON ---
  VIFTE
  VARMEBATTERI_VENT
  KJOLEBATTERI
  ROTOR_GJENVINNER

  // --- KJOLING ---
  CHILLER
  DX_AGGREGAT
  TORRKJOLER
  PROSESSKJOLING

  // --- VARMEPUMPE ---
  VP_PRODUKSJON
  VP_KALD_SIDE
  VP_VARM_SIDE

  // --- STIKKONTAKT ---
  KJOKKEN
  LAB
  VERKSTED
  KONTOR
  PROSESSUTSTYR

  // --- BELYSNING ---
  INNVENDIG_BELYSNING
  UTVENDIG_BELYSNING
  NODBELYSNING

  // --- IT_DATAROM ---
  IT_LAST
  UPS
  IT_KJOLING

  // --- TEKNISK ---
  AUTOMASJON
  STYRING
  MIDLERTIDIG_STROM

  // --- TAPPEVANN ---
  VVB
  SIRKULASJONSPUMPE

  // --- HEIS ---
  PERSONHEIS
  VAREHEIS
  RULLETRAPP

  // --- ELBIL_LADING ---
  NORMALLADER
  HURTIGLADER

  // --- SOLCELLE ---
  PV_PANEL
  INVERTER
  BATTERILAGRING
}

model User {
  id                                  String                               @id @default(cuid())
  clerkUserId                         String                               @unique
  email                               String                               @unique
  firstName                           String?
  lastName                            String?
  imageUrl                            String?
  /// Plattform-superadmin (Scoped drift/støtte). **Skal aldri** settes automatisk fra org-admin i Clerk — bruk `OrganizationToUsers.role` / `PersonDefinition.role` (`AppRole`) for det.
  isAdmin                             Boolean                              @default(false)
  lastSignInAt                        DateTime?                            @default(now())
  lastActiveAt                        DateTime?
  createdAt                           DateTime                             @default(now())
  updatedAt                           DateTime                             @updatedAt
  alertDefaults                       Boolean                              @default(false)
  quietHoursEnabled                   Boolean                              @default(false)
  quietHoursStart                     Int?
  quietHoursEnd                       Int?
  quietHoursMinPriority               NotificationPriority?                @default(CRITICAL)
  organizations                       OrganizationToUsers[]
  reviewedObservations                Observation[]
  classifiedMeteringPoints            MeteringPoint[]                      @relation("MeteringPointClassifier")

  @@map("users")
}

model OrganizationToUsers {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           AppRole      @default(MANAGER)
  createdAt      DateTime     @default(now())
  organizations  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@map("organization_to_users")
}

model Organization {
  id                             String                          @id @default(cuid())
  name                           String
  clerkOrgId                     String                          @unique
  imageUrl                       String?
  onboardingCompleted            Boolean                         @default(false)
  createdAt                      DateTime                        @default(now())
  updatedAt                      DateTime                        @updatedAt
  integrations                   Integration[]
  meteringPoints                 MeteringPoint[]
  users                          OrganizationToUsers[]
  infraspawnSources              InfraspawnSource[]

  @@index([name])
  @@index([onboardingCompleted])
  @@index([createdAt])
  @@map("organizations")
}

model Integration {
  id                       String               @id @default(cuid())
  organizationId           String
  provider                 IntegrationProvider
  type                     IntegrationType
  status                   IntegrationStatus    @default(PENDING_SETUP)
  clientId                 String?
  clientSecretEncrypted    String?
  subscriptionKeyEncrypted String?
  apiUrl                   String?
  identityUrl              String?
  accessToken              String?
  tokenExpiresAt           DateTime?
  lastSyncAt               DateTime?
  lastSuccessfulSyncAt     DateTime?
  metadata                 Json?                @default("{}")
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  organization             Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  meteringPoints           MeteringPoint[]
  infraspawnSources        InfraspawnSource[]

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([provider])
  @@index([type])
  @@index([status])
  @@index([lastSyncAt])
  @@map("integrations")
}

model InfraspawnSource {
  id                   String    @id @default(cuid())
  integrationId        String
  organizationId       String
  buildingId           String
  label                String
  influxDatabase       String
  apiTokenEncrypted    String
  isActive             Boolean   @default(true)
  lastSyncAt           DateTime? @db.Timestamptz(6)
  lastSuccessfulSyncAt DateTime? @db.Timestamptz(6)
  lastError            String?
  metadata             Json?     @default("{}")
  createdAt            DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @db.Timestamptz(6)

  integration  Integration                 @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  organization Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  building     Building                    @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  pointMeta    InfraspawnBacnetPointMeta[]
  samples      InfraspawnBacnetSample[]
  syncState    InfraspawnSyncState?
  alarmEvents  InfraspawnAlarmEvent[]

  @@unique([integrationId, influxDatabase])
  @@index([organizationId])
  @@index([integrationId])
  @@index([buildingId])
  @@index([isActive])
  @@map("infraspawn_sources")
}

model InfraspawnBacnetPointMeta {
  id          String   @id @default(cuid())
  sourceId    String
  objectId    String
  objectName  String?
  description String?
  unit        String?
  rawMetadata Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  source InfraspawnSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, objectId])
  @@index([sourceId])
  @@map("infraspawn_bacnet_point_meta")
}

model InfraspawnBacnetSample {
  id          String   @id @default(cuid())
  sourceId    String
  objectId    String
  sampledAt   DateTime @db.Timestamptz(6)
  resolution  String   @default("hour")
  valueNum    Float?
  quality     String?
  sampleCount Int?
  raw         Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  source InfraspawnSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, objectId, sampledAt, resolution])
  @@index([sourceId, resolution, sampledAt])
  @@map("infraspawn_bacnet_samples")
}

model InfraspawnSyncState {
  id           String    @id @default(cuid())
  sourceId     String    @unique
  watermarkAt  DateTime? @db.Timestamptz(6)
  lastRunAt    DateTime? @db.Timestamptz(6)
  rowsUpserted Int       @default(0)
  status       String    @default("IDLE")
  lastError    String?
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)

  source InfraspawnSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@map("infraspawn_sync_states")
}

model InfraspawnAlarmEvent {
  id                String                   @id @default(cuid())
  sourceId          String
  objectId          String
  buildingId        String
  kind              InfraspawnAlarmKind
  severity          InfraspawnAlarmSeverity
  alarmText         String
  valueAtActivation Float?
  valueAtClear      Float?
  activatedAt       DateTime                 @db.Timestamptz(6)
  clearedAt         DateTime?                @db.Timestamptz(6)
  domain            InfraspawnSystemDomain?
  metadata          Json?                    @default("{}")
  /// Unik mens åpen: `{sourceId}:{objectId}:{kind}`. Null etter clear — idempotent opprettelse.
  openDedupeKey     String?
  createdAt         DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime                 @updatedAt @db.Timestamptz(6)

  source   InfraspawnSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  building Building         @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([openDedupeKey])
  @@index([buildingId, clearedAt, activatedAt(sort: Desc)])
  @@index([sourceId, clearedAt])
  @@index([sourceId, objectId, clearedAt])
  @@map("infraspawn_alarm_events")
}

model SdAnleggSiteProfile {
  id                String   @id @default(cuid())
  buildingId        String   @unique
  displayTitle      String?
  heroImageUrl      String?
  clientLogoUrl     String?
  contactName       String?
  contactPhone      String?
  contactLabel      String?
  featuredPointRefs Json?    @default("[]")
  metadata          Json?    @default("{}")
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@map("sd_anlegg_site_profiles")
}

/// Kompakt MPC replay-steg per bygg — canonical simuleringsintervall (typisk 15 min).
model SdAnleggMpcReplayStep {
  id                     String   @id @default(cuid())
  buildingId             String
  stepAt                 DateTime @db.Timestamptz(6)
  stepMinutes            Int      @default(15)
  modelVersion           String   @default("mpc-v1")
  calibrationFingerprint String
  /// Kompakt payload — se lib/sd-anlegg/control/compact-mpc-replay-step.ts
  payload                Json
  createdAt              DateTime @default(now()) @db.Timestamptz(6)

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, stepAt, stepMinutes, modelVersion])
  @@index([buildingId, stepAt])
  @@index([buildingId, stepMinutes, stepAt])
  @@index([buildingId, calibrationFingerprint, stepAt])
  @@map("sd_anlegg_mpc_replay_steps")
}

/// Materialisert timevis styringssignal per bygg — beholdes for bakoverkompatibilitet.
model SdAnleggControlSignalHour {
  id                     String   @id @default(cuid())
  buildingId             String
  hourAt                 DateTime @db.Timestamptz(6)
  modelVersion           String   @default("mpc-v1")
  calibrationFingerprint String?
  pipelineRunId          String?
  /// Gjennomsnitt observert/emulert/mpc/demand — se compact-control-signal-hour.ts
  payload                Json
  /// Antall 15-min steg som inngår i timen
  stepCount              Int      @default(0)
  createdAt              DateTime @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @db.Timestamptz(6)

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, hourAt, modelVersion])
  @@index([buildingId, hourAt(sort: Desc)])
  @@map("sd_anlegg_control_signal_hours")
}

/// Materialisert styringssignal i valgfri oppløsning (1/5/15/60 min) — rask graf og BMS-planlegging.
model SdAnleggControlSignalBucket {
  id                     String   @id @default(cuid())
  buildingId             String
  bucketAt               DateTime @db.Timestamptz(6)
  bucketMinutes          Int
  /// mpc_replay | sd_observed
  sourceKind             String   @default("mpc_replay")
  modelVersion           String   @default("mpc-v1")
  calibrationFingerprint String?
  pipelineRunId          String?
  payload                Json
  stepCount              Int      @default(0)
  createdAt              DateTime @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime @updatedAt @db.Timestamptz(6)

  building Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, bucketAt, bucketMinutes, modelVersion, sourceKind])
  @@index([buildingId, bucketMinutes, bucketAt(sort: Desc)])
  @@index([buildingId, sourceKind, bucketMinutes, bucketAt(sort: Desc)])
  @@map("sd_anlegg_control_signal_buckets")
}

/// Live MPC-tilstand: kalibrering, watermark, writeback-modus.
model SdAnleggLiveMpcState {
  buildingId             String   @id
  lookbackDays           Int      @default(7)
  modelVersion           String   @default("mpc-v1")
  executionMode          MpcExecutionMode @default(SUPERVISORY)
  calibrationFingerprint String
  calibration            Json?
  plantRmseC             Float?
  emulatorMaeSupplySetpointC Float?
  evalStart              DateTime? @db.Timestamptz(6)
  evalEnd                DateTime? @db.Timestamptz(6)
  replayWatermarkAt      DateTime? @db.Timestamptz(6)
  /// Siste mpc-v1 day-ahead plan (bygget etter replay i cron/manuell kjøring).
  forwardPlan            Json?
  /// Map policyId → forward plan (mpc-v1, demand-scoped, …).
  forwardPlans           Json?
  /// Siste control-tick (15-min receding horizon etter SD-sync).
  lastControlTickAt      DateTime? @db.Timestamptz(6)
  /// Diff mot forrige forward plan ved siste tick.
  lastPlanDiff           Json?
  /// Aktiv settpunktvektor (u[0] etter regulator) fra siste tick.
  activeCommand          Json?
  /// Peker til aktiv eller sist fullførte simuleringsjobb.
  activeSimulationJobId  String?  @unique
  updatedAt              DateTime @updatedAt @db.Timestamptz(6)

  building            Building                 @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  controlTicks        SdAnleggControlTick[]
  activeSimulationJob SdAnleggMpcSimulationJob? @relation(fields: [activeSimulationJobId], references: [id], onDelete: SetNull)

  @@map("sd_anlegg_live_mpc_states")
}

/// Audit-spor for lang eval-replay (historikk + aktiv jobb).
model SdAnleggMpcSimulationJob {
  id               String              @id @default(cuid())
  buildingId       String
  pipelineRunId    String?
  status           MpcSimulationStatus @default(RUNNING)
  executionMode    MpcExecutionMode    @default(SHADOW)
  stepMinutes      Int                 @default(15)
  triggerSource    String              @default("manual")
  inputFingerprint String?
  stepTotal        Int                 @default(0)
  stepIndex        Int                 @default(0)
  message          String?
  startedAt        DateTime            @default(now()) @db.Timestamptz(6)
  finishedAt       DateTime?           @db.Timestamptz(6)
  durationMs       Int?
  errorMessage     String?
  /// Gjenopptak: replayIndex, loopState, inputFingerprint, pipelineRunId.
  checkpoint       Json?
  createdAt        DateTime            @default(now()) @db.Timestamptz(6)

  building      Building               @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  pipelineRun   SdAnleggMpcPipelineRun? @relation(fields: [pipelineRunId], references: [id], onDelete: SetNull)
  liveMpcState  SdAnleggLiveMpcState?

  @@index([buildingId, createdAt(sort: Desc)])
  @@index([buildingId, status])
  @@map("sd_anlegg_mpc_simulation_jobs")
}

/// Logg per control-tick — plan-diff, aktiv kommando og effekt-estimat.
model SdAnleggControlTick {
  id                     String   @id @default(cuid())
  buildingId             String
  tickAt                 DateTime @db.Timestamptz(6)
  triggerSource          String   @default("cron")
  modelVersion           String   @default("mpc-v1")
  calibrationFingerprint String
  planDiff               Json?
  activeCommand          Json
  forwardPlanEffect      Json?
  stateSnapshot          Json?
  createdAt              DateTime @default(now()) @db.Timestamptz(6)

  building     Building              @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  liveMpcState SdAnleggLiveMpcState @relation(fields: [buildingId], references: [buildingId], onDelete: Cascade, map: "sd_anlegg_control_ticks_live_mpc_state_fkey")

  @@index([buildingId, tickAt(sort: Desc)])
  @@map("sd_anlegg_control_ticks")
}

/// MPC-pipeline (mpc-v1) — historisk eval-replay og thesis-bevis.
model SdAnleggMpcPipelineRun {
  id                 String   @id @default(cuid())
  buildingId         String
  modelVersion       String   @default("mpc-v1")
  executionMode      MpcExecutionMode @default(SHADOW)
  stepMinutes        Int              @default(15)
  evalStart          DateTime @db.Timestamptz(6)
  evalEnd            DateTime @db.Timestamptz(6)
  inputFingerprint   String
  stepCount          Int
  trainStepCount     Int
  holdoutStepCount   Int
  /// Kalibrering (emulator/plant/power) — eneste JSON-blob på run.
  calibration        Json?
  replayQuality      MpcReplayQuality?
  signalBindingVersion String?
  totalCostBaselineKr             Float?
  totalCostEmulatedKr             Float?
  totalCostMpcKr                  Float?
  totalCostDemandKr               Float?
  deltaCostKr                     Float?
  deltaCostPct                    Float?
  deltaCostVsEmulatedKr           Float?
  deltaCostVsEmulatedPct          Float?
  controllableElectricKwhBaseline Float?
  controllableElectricKwhEmulated Float?
  controllableElectricKwhMpc        Float?
  controllableHeatKwhBaseline     Float?
  controllableHeatKwhEmulated     Float?
  controllableHeatKwhMpc          Float?
  peakElectricKwBaseline          Float?
  peakElectricKwEmulated          Float?
  peakElectricKwMpc               Float?
  fallbackSteps                   Int?
  optimizablePct                  Float?
  meaningfulDeltaPct              Float?
  plantRmseC                      Float?
  emulatorMaeSupplySetpointC      Float?
  comfortViolationsMpc            Int?
  comfortViolationsBaseline       Int?
  comfortViolationsEmulated       Int?
  comfortViolationsDemand         Int?
  comfortViolationsObservedProxy  Int?
  comfortViolationsHarmonizedObserved Int?
  measuredElectricityKwh          Float?
  measuredDistrictHeatingKwh       Float?
  measuredTotalCostKr             Float?
  proxyEmulatedCostKr             Float?
  proxyMpcCostKr                  Float?
  deltaMpcVsEmulatedCostKr        Float?
  deltaMpcVsEmulatedCostPct       Float?
  chartsGeneratedAt               DateTime? @db.Timestamptz(6)
  persistStatus                   MpcPersistStatus?
  persistedStepCount              Int?
  persistError                    String?
  uiArtifacts                     Json?
  /// Siste end-to-end verifikasjon (replay-steg vs run-scalars).
  verificationHealth              String?
  verifiedAt                      DateTime? @db.Timestamptz(6)
  createdAt          DateTime @default(now()) @db.Timestamptz(6)

  building               Building                        @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  energyReconcileHours   SdAnleggMpcEnergyReconcileHour[]
  replayStepRows         SdAnleggMpcPipelineReplayStep[]
  supervisoryCommands    SdAnleggSupervisoryCommand[]
  policyKpis             SdAnleggMpcPolicyKpi[]
