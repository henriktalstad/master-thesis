model Building {
  id                                  String                               @id @default(cuid())
  name                                String                               @unique
  description                         String?
  address                             String
  postCode                            String
  postalPlace                         String
  region                              String
  buildingSize                        Float
  btaSqm                              Float?
  tenantLeaseAreaCapBasis             AreaMeasurementBasis                 @default(BRA)
  imageUrl                            String?
  buildingYear                        Int?
  municipalityNumber                  String?
  municipalityName                    String?
  propertyNumber                      String?
  sectionNumber                       String?
  shareNumber                         String?
  shareHolderNumber                   String?
  availableUnits                      String[]
  buildingTypes                       String[]
  createdAt                           DateTime                             @default(now())
  updatedAt                           DateTime                             @updatedAt
  selectedGridOperatorId              String?
  slug                                String?                              @unique
  applicableTEKStandard               String?
  targetTEKStandard                   String?                              @default("TEK17")
  climateTargets                      Json?
  comfortTargets                      Json?
  energyLabelTarget                   String?
  gapAnalysisFrequency                String?                              @default("ANNUAL")
  lastGapAnalysisAt                   DateTime?
  passivehusTarget                    Boolean                              @default(false)
  buildingCategories                  String[]                             @default([])
  latitude                            Float?
  longitude                           Float?
  addresses                           BuildingAddress[]                    @relation("BuildingAddresses")
  BuildingHourlyCosts                 BuildingHourlyCostCache[]
  selectedGridOperator                GridOperator?                        @relation(fields: [selectedGridOperatorId], references: [id])
  meteringPointLinks                  MeteringPointToBuildings[]
  meteringPoints                      MeteringPoint[]
  /// Satt når spot/tariff el.l. endrer seg slik at BHCC/dag-rollup bør kjøres på nytt selv om måler-cache ikke får ny `calculatedAt`. Nullstilles etter vellykket rollup i `hourly-costs.sync`.
  costRollupInvalidatedAt             DateTime?                            @db.Timestamptz(6)
  allocationMethod                    String?
  /// Gjeldende spor etter siste aktivert fordelingsnøkkel. Null: ikke satt (eldre bygg / ingen aktivering ennå).
  /// Ved lesing utledes effektivt spor fra aktiv nøkkels `source` når den avviker fra dette feltet (se server batch-status).
  allocationTrack                     AllocationTrack?
  infraspawnSources                   InfraspawnSource[]
  infraspawnAlarmEvents               InfraspawnAlarmEvent[]
  sdAnleggSiteProfile                 SdAnleggSiteProfile?
  sdAnleggMpcPipelineRuns             SdAnleggMpcPipelineRun[]
  sdAnleggMpcPipelineReplaySteps     SdAnleggMpcPipelineReplayStep[]
  sdAnleggMpcPreferences              SdAnleggMpcPreferences?
  sdAnleggMpcReplaySteps              SdAnleggMpcReplayStep[]
  sdAnleggControlSignalHours          SdAnleggControlSignalHour[]
  sdAnleggControlSignalBuckets        SdAnleggControlSignalBucket[]
  sdAnleggSupervisoryCommands         SdAnleggSupervisoryCommand[]
  sdAnleggLiveMpcState                SdAnleggLiveMpcState?
  sdAnleggMpcSimulationJobs           SdAnleggMpcSimulationJob[]
  sdAnleggControlTicks                SdAnleggControlTick[]
  thesisEvalPeriods                   ThesisEvalPeriod[]
  thesisExportRuns                    ThesisExportRun[]
  weatherStation                      BuildingWeatherStation?

  // --- Metering topology (sub-metering refactor) ---
  // Bestemmer hvilken "total energi"-formel som gjelder for bygget.
  // SUB_METER_ONLY: alle målere er interne (Travbanevegen 2). Total = Hovedfordeling.
  // GRID_AMS_ONLY: kun AMS på nettpunkt. Total = AMS-import + fjernvarme + fjernkjøling.
  // KPI-er flagges som "foreløpige" inntil meteringTopologyVerifiedAt er satt.
  meteringTopology             BuildingMeteringTopology @default(UNKNOWN)
  meteringTopologyVerifiedAt   DateTime?
  meteringTopologyNotes        String?
  hasUnregisteredHeatSource    Boolean                  @default(false)
  hasUnregisteredCoolingSource Boolean                  @default(false)

  @@unique([name, address])
  @@index([municipalityNumber, propertyNumber, sectionNumber])
  @@index([municipalityNumber, propertyNumber, sectionNumber, shareNumber])
  @@index([address, postCode])
  @@index([postCode])
  @@index([buildingCategories])
  @@index([buildingYear])
  @@index([region])
  @@index([selectedGridOperatorId])
  @@index([name])
  @@index([slug])
  @@index([latitude], map: "buildings_lat_idx")
  @@index([longitude], map: "buildings_lon_idx")
  @@index([meteringTopology], map: "buildings_metering_topology_idx")
  @@index([costRollupInvalidatedAt])
  @@index([allocationTrack])
  @@map("buildings")
}

model BuildingAddress {
  id             String   @id @default(cuid())
  buildingId     String
  address        String
  normalizedAddr String
  postCode       String
  postalPlace    String
  isPrimary      Boolean  @default(false)
  numberFrom     Int?
  numberTo       Int?
  letterFrom     String?
  letterTo       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  building       Building @relation("BuildingAddresses", fields: [buildingId], references: [id], onDelete: Cascade)

  @@unique([buildingId, normalizedAddr, postCode], map: "building_addresses_buildingid_normalizedaddr_postcode_key")
  @@index([buildingId])
  @@index([normalizedAddr, postCode])
  @@map("building_addresses")
}

model WeatherStation {
