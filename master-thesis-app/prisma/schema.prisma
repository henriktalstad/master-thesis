  createdAt    DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @db.Timestamptz(6)
  observations WeatherObservation[]
  station      WeatherStation       @relation(fields: [stationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "weather_series_station_fk")

  @@unique([stationId, elementId, resolution, level], map: "weather_series_unique")
  @@index([elementId, resolution], map: "weather_series_element_resolution_idx")
  @@index([stationId], map: "weather_series_station_idx")
