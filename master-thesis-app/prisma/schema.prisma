model BuildingWeatherStation {
  buildingId           String         @id
  stationId            String
  stationName          String?
  distanceKm           Float
  primaryResolution    String
  resolutionsAvailable String[]       @default([])
  chosenAt             DateTime       @default(now()) @db.Timestamptz(6)
  method               String         @default("distance_then_resolution_5km")
  firstObservationAt   DateTime?      @db.Timestamptz(6)
  lastObservationAt    DateTime?      @db.Timestamptz(6)
  building             Building       @relation(fields: [buildingId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "building_weather_station_building_fk")
  station              WeatherStation @relation(fields: [stationId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "building_weather_station_station_fk")

  @@index([stationId], map: "building_weather_station_station_idx")
  @@map("building_weather_station")
}

model MeteringPoint {
  id                    String                @id @default(cuid())
  mpid                  String                @unique
  name                  String?
  address               String?
  postalCode            String?
  postalPlace           String?
  region                String?
  type                  MeteringPointType     @default(ELECTRICITY)
  BRA                   String?
  BTA                   String?
  intensityAreaBasis    AreaMeasurementBasis?
  isActive              Boolean               @default(true)
  lastFetchedAt         DateTime?
  createdAt             DateTime              @default(now())
  clerkOrgId            String
  buildingId            String?
  firstObservationAt    DateTime?
  lastObservationAt     DateTime?
  technicalSharePct     Float?
  integrationId         String?
  backfillState         BackfillState         @default(BASELINE)
  backfillCursorFrom    DateTime?
  backfillEmptyStreak   Int                   @default(0)
  backfillNextRunAt     DateTime?
  apiFirstObservationAt DateTime?
  apiLastObservationAt  DateTime?
  parentMeteringPointId String?
  isSubMeter            Boolean               @default(false)
  /// @deprecated Bruk `flowStage` + `hierarchyRole` (sub-metering refactor Fase 4).
  /// Kolonnen beholdes inntil alle dashboards er migrert til
  /// computeTotalForTopology fra src/lib/energy-totals.
  includeInTotal        Boolean               @default(true)
  subMeterCategory      SubMeterCategory?
  subMeterSubCategory   SubMeterSubCategory?
  subMeterLabel         String?
  meterLocation         String? // Fysisk plassering, f.eks. "Hovedtavle 432.101", "Ventilasjonsrom Kjeller"
  externalSubMeterId    String?
  folderId              String?
  isIncremental         Boolean               @default(false)
  lastImportRawValue    Float?
  lastImportRawTime     DateTime?

  // --- Energi-flow-klassifisering (sub-metering refactor) ---
  // Hvor i energiflyten sitter måleren (skiller produksjon fra distribusjon for varme/kjøling)
  flowStage           EnergyFlowStage?
  // Hierarki-rolle: TOTAL/BRANCH/LEAF/STANDALONE — eksplisitt vs avledet fra parentMeteringPointId
  hierarchyRole       MeterHierarchyRole?
  // Fysisk CT/varmemåler-plassering — kritisk for korrekt PV-tolkning og dobbelttellings-vern
  ctPlacement         CtPlacement?
  // Hvor energien i denne måleren kommer fra. Brukes for DISTRIBUTION-målere som
  // stammer fra en PRODUCTION_GROSS-måler — løser dobbelttelling på tvers av bærere.
  // Eksempel: gulvvarme-måler.energySourcedFromId = varmepumpe-måler.id
  energySourcedFromId String?
  // Når og av hvem ble klassifiseringen satt (for "needs review"-kø)
  classifiedAt        DateTime?
  classifiedByUserId  String?
  classificationNotes String?
  verificationStatus  MeterVerificationStatus @default(AUTO)
  // Eksplisitt kundevalg for om en måler er fakturerbar eller ikke
  isTenantBillable    Boolean?

  energySourcedFrom MeteringPoint?  @relation("EnergyFlow", fields: [energySourcedFromId], references: [id], onDelete: SetNull)
  energyFlowsTo     MeteringPoint[] @relation("EnergyFlow")
  classifiedBy      User?           @relation("MeteringPointClassifier", fields: [classifiedByUserId], references: [id], onDelete: SetNull)

  districtHeatingMeasurements DistrictHeatingMeasurement[]
  buildingLinks               MeteringPointToBuildings[]
  building                    Building?                              @relation(fields: [buildingId], references: [id])
  organizations               Organization                           @relation(fields: [clerkOrgId], references: [clerkOrgId])
  integration                 Integration?                           @relation(fields: [integrationId], references: [id], onUpdate: NoAction)
  accumulatedObservations     AccumulatedObservation[]
  observations                Observation[]
  parentMeteringPoint         MeteringPoint?                         @relation("SubMeters", fields: [parentMeteringPointId], references: [id], onDelete: SetNull)
  subMeters                   MeteringPoint[]                        @relation("SubMeters")
  placements                  MeteringPointPlacement[]

  @@index([mpid])
  @@index([clerkOrgId])
  @@index([buildingId])
  @@index([integrationId])
  @@index([isActive])
  @@index([lastFetchedAt])
  @@index([firstObservationAt])
  @@index([lastObservationAt])
  @@index([backfillState])
  @@index([backfillNextRunAt])
  @@index([apiFirstObservationAt])
  @@index([apiLastObservationAt])
  @@index([parentMeteringPointId])
  @@index([externalSubMeterId])
  @@index([isSubMeter])
  @@index([includeInTotal])
  @@index([folderId])
  @@index([name]) // For søk på navn
  @@index([clerkOrgId, buildingId], map: "metering_points_org_buildingid_idx")
  @@index([clerkOrgId, isActive], map: "metering_points_org_isactive_idx")
  @@index([clerkOrgId, lastObservationAt], map: "metering_points_org_lastobservationat_idx")
  @@index([clerkOrgId, type], map: "metering_points_org_type_idx")
  @@index([type, isActive], map: "metering_points_type_isactive_idx") // For filtrering på type + status
  @@index([clerkOrgId, type, isActive], map: "metering_points_org_type_isactive_idx") // Sammensatt for dashboard
  @@index([type, lastObservationAt], map: "metering_points_type_lastobs_idx") // For sortering per type
  @@index([isActive, lastObservationAt, id], map: "mp_active_lastobs_id_idx")
  @@index([flowStage], map: "metering_points_flow_stage_idx")
  @@index([hierarchyRole], map: "metering_points_hierarchy_role_idx")
  @@index([ctPlacement], map: "metering_points_ct_placement_idx")
  @@index([energySourcedFromId], map: "metering_points_energy_sourced_from_idx")
  @@index([buildingId, flowStage], map: "metering_points_building_flow_stage_idx")
  @@map("metering_points")
}

model MeteringPointPlacement {
  id              String @id @default(cuid())
  meteringPointId String

  // Valgfri kobling til versjonert arealgrunnlag eller direkte plantegning
  areaPlanVersionId   String?
  areaSpaceSnapshotId String?
  floorPlanId         String?

  // Hvor stor del (%) av målepunktet som dekkes av denne plasseringen (valgfritt).
  // Brukes når et målepunkt kobles til flere rom/områder.
  coveragePct Float?

  // UI-ankring (f.eks. {x,y} + koordinatsystem)
  anchorJson Json
  metadata   Json?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  meteringPoint     MeteringPoint      @relation(fields: [meteringPointId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([meteringPointId], map: "mpp_meteringpoint_idx")
  @@index([areaPlanVersionId], map: "mpp_areaplanversion_idx")
  @@index([areaSpaceSnapshotId], map: "mpp_areasnapshot_idx")
  @@index([floorPlanId], map: "mpp_floorplan_idx")
  @@map("metering_point_placements")
}

model MeteringPointToBuildings {
  id              String        @id @default(cuid())
  meteringPointId String
  buildingId      String
  matchMethod     String?
  confidence      Float?
  isPrimary       Boolean       @default(false)
  weightPct       Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  building        Building      @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  meteringPoint   MeteringPoint @relation(fields: [meteringPointId], references: [id], onDelete: Cascade)

  @@unique([meteringPointId, buildingId], map: "metering_point_to_buildings_unique")
  @@index([meteringPointId])
  @@index([buildingId])
  @@map("metering_point_to_buildings")
}

model Observation {
  id              String               @id @default(cuid())
  /// Lokalt/legacy tidspunkt (ofte norsk offset i eldre synk); prefer `utcTime` for aggregering.
  time            DateTime
  /// Kanonisk tidsstempel for bucket/agregat; unik per måler sammen med `meteringPointId`.
  utcTime         DateTime
  direction       String
  method          String
  /// Mengde i intervallet — kWh for energibærere; vann bruker samme kolonne med annen tolkning (se modellkommentar over).
  volume_kwh      Float
  meteringPointId String
  meteringPoint   MeteringPoint        @relation(fields: [meteringPointId], references: [id])

  // Anomaly review fields - when set, the observation is excluded from anomaly detection
  reviewedAt       DateTime? @db.Timestamptz(6)
  reviewedByUserId String?
  reviewedByUser   User?     @relation(fields: [reviewedByUserId], references: [id])

  /// Én rad per (målepunkt, utcTime); hindrer duplikater ved gjenimport.
  @@unique([meteringPointId, utcTime])
  @@index([meteringPointId])
  @@index([time])
  @@index([utcTime])
  @@index([meteringPointId, time])
  @@index([meteringPointId, utcTime])
  @@index([meteringPointId, time, volume_kwh])
  @@map("observations")
}

model AccumulatedObservation {
  id                       String               @id
  meteringPointId          String?
  importPlaceholderMeterId String?
  source                   IntegrationProvider?
  sourceTimestampRaw       String
  sourceTimestampParsed    DateTime?
  rawValue                 Float
  createdAt                DateTime             @default(now())

  meteringPoint          MeteringPoint?          @relation(fields: [meteringPointId], references: [id], onDelete: Cascade)

  @@unique([meteringPointId, sourceTimestampRaw])
  @@unique([importPlaceholderMeterId, sourceTimestampRaw])
  @@index([meteringPointId, sourceTimestampParsed])
  @@index([importPlaceholderMeterId, sourceTimestampParsed])
  @@index([source])
  @@index([createdAt])
  @@map("accumulated_observations")
}

model DistrictHeatingMeasurement {
  id              String        @id @default(cuid())
  time            DateTime
  utcTime         DateTime
  meteringPointId String
  energyKwh       Float?
  flowM3h         Float?
  forwardTempC    Float?
  returnTempC     Float?
  diffTempK       Float?
  volumeM3        Float?
  resolution      String        @default("hour")
  metadata        Json?
  createdAt       DateTime      @default(now())
  meteringPoint   MeteringPoint @relation(fields: [meteringPointId], references: [id], onDelete: Cascade)

  @@unique([meteringPointId, utcTime])
  @@index([meteringPointId, time])
  @@index([meteringPointId, resolution])
  @@index([time])
  @@index([utcTime])
  @@map("district_heating_measurements")
}

model DailyEnergyPrices {
  id           String             @id @default(cuid())
  date         DateTime?
  averagePrice Float?
  areaCode     String?
  /// `NORD_POOL` = spotpriser.csv / Nord Pool. `ENTSOE` = day-ahead sync. ENTSO-E overskriver ikke NORD_POOL.
  source       EnergyPriceSource?
  avg7d        Float?
  avg30d       Float?
  avg365d      Float?
  trend7dPct   Float?
  trend30dPct  Float?
  trend365dPct Float?
  createdAt    DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @db.Timestamptz(6)

  @@unique([date, areaCode])
  @@index([date])
  @@index([areaCode])
  @@index([date, areaCode, averagePrice])
  @@index([date, areaCode], map: "daily_energy_prices_date_area_idx")
  @@index([updatedAt])
  @@map("daily_energy_prices")
}

model HourlyEnergyPrices {
  id        String             @id @default(cuid())
  date      DateTime?
  hour      Int?
  /// Spotpris i **kr/kWh** (ikke øre/kWh). Kostlag multipliserer med 100 ved behov.
  price     Float?
  areaCode  String?
  /// Se `EnergyPriceSource` – CSV/Nord Pool har prioritet over ENTSO-E.
  source    EnergyPriceSource?
  createdAt DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @db.Timestamptz(6)

  @@unique([date, hour, areaCode])
  @@index([date, hour])
  @@index([areaCode])
  @@index([date, areaCode])
  @@index([areaCode, date, price], map: "hourly_energy_prices_area_date_price_idx")
  @@index([date, hour, areaCode, price])
  @@index([updatedAt])
  @@map("hourly_energy_prices")
}

/// Kanonisk ENTSO-E day-ahead (PT15M). Time/dag avledes som aritmetisk snitt.
model QuarterHourlyEnergyPrices {
  id        String             @id @default(cuid())
  date      DateTime?          @db.Timestamptz(6)
  hour      Int?
  /// 0–3 (= :00, :15, :30, :45 UTC innen `hour`)
  quarter   Int?
  /// Spotpris i **kr/kWh**
  price     Float?
  areaCode  String?
  source    EnergyPriceSource?
  createdAt DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @db.Timestamptz(6)

  @@unique([date, hour, quarter, areaCode])
  @@index([date, hour, quarter])
  @@index([areaCode])
  @@index([date, areaCode])
  @@index([areaCode, date, price], map: "quarter_hourly_energy_prices_area_date_price_idx")
  @@index([updatedAt])
  @@map("quarter_hourly_energy_prices")
}

model GridOperator {
  id                         String                      @id @default(cuid())
  name                       String                      @unique
  organizationNumber         String                      @unique
  counties                   String[]
  active                     Boolean                     @default(true)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  buildings                  Building[]
  gridTariffs                GridTariff[]

  @@index([organizationNumber])
  @@map("grid_operators")
}

model GridTariff {
  id                         String                       @id @default(cuid())
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  gridOperatorId             String
  county                     String
  timestamp                  DateTime
  tariffGroup                Int
  energyLink                 Float
  fixedLink                  Float
  capacityLink               Float?
  powerStageFromKw           Float?
  powerstageToKw             Float?
  basisPowerStage            String?
  yearTrend                  Float
  monthTrend                 Float?
  weekTrend                  Float?
  gridOperator               GridOperator                 @relation(fields: [gridOperatorId], references: [id], onDelete: Cascade)

  @@unique([gridOperatorId, county, timestamp, tariffGroup, powerStageFromKw, powerstageToKw])
  @@index([gridOperatorId])
  @@index([county])
  @@index([timestamp])
  @@index([powerStageFromKw, powerstageToKw])
  @@map("grid_tariffs")
}

model BuildingHourlyCostCache {
  id         String   @id @default(cuid())
  buildingId String
  hour       DateTime @db.Timestamptz(6)

  // Elektrisitet
  electricitySpotCost           Float  @default(0)
  electricityGridEnergyCost     Float  @default(0)
  electricityFixedAllocKr       Float  @default(0)
  electricityTotalCost          Float  @default(0)
  electricityConsumptionTaxCost Float  @default(0)
  electricityVolumeKwh          Float?
  electricityPriceNokPerKwh     Float?

  // Termisk kjøling (MP-type COOLING) — samme struktur som elektrisitet; ikke blandes med electricity*.
  coolingSpotCost           Float  @default(0)
  coolingGridEnergyCost     Float  @default(0)
  coolingFixedAllocKr       Float  @default(0)
  coolingTotalCost          Float  @default(0)
  coolingConsumptionTaxCost Float  @default(0)
  coolingVolumeKwh          Float?
  coolingPriceNokPerKwh     Float?

  // Produksjon (MP-type PRODUCTION)
  productionSpotCost           Float  @default(0)
  productionGridEnergyCost     Float  @default(0)
  productionFixedAllocKr       Float  @default(0)
  productionTotalCost          Float  @default(0)
  productionConsumptionTaxCost Float  @default(0)
  productionVolumeKwh          Float?
  productionPriceNokPerKwh     Float?

  // Fjernvarme
  districtHeatingSpotCost       Float  @default(0)
  districtHeatingDiscountAmount Float  @default(0)
  districtHeatingEffectCost     Float  @default(0)
  districtHeatingFixedCost      Float  @default(0)
  districtHeatingNetworkCost    Float  @default(0)
  districtHeatingAdminCost      Float  @default(0)
  districtHeatingElectricityTax Float  @default(0)
  districtHeatingTotalCost      Float  @default(0)
  districtHeatingVolumeKwh      Float?
  districtHeatingPriceNokPerKwh Float?

  /// Kilde for spotpris brukt i rollup (NORD_POOL / ENTSOE).
  spotPriceSource EnergyPriceSource?
  /// Identifiserer hvilken sync-jobb/pipeline som produserte raden.
  rollupSource    String             @default("building_hourly_costs_sync")

  calculatedAt DateTime @default(now()) @db.Timestamptz(6)
  building     Building @relation(fields: [buildingId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([buildingId, hour])
  @@index([buildingId])
  @@index([hour])
  @@index([buildingId, hour], map: "bhcc_building_hour_idx")
  @@index([calculatedAt])
  @@map("building_hourly_cost_cache")
}
